#include <stdio.h>

int main()
{
   int arr[5];
   int i,d=0;
   
   
   printf("Enter any 5 numbers\n");
   for(int i=0;i<5;i++)
   {
       scanf("%d",&arr[i]);
       d=d+arr[i];
   }
   printf("sum of all the numbers =%d\n",d);
   float avg=d/5;
   printf("average of the array =%.2f",avg);
   
    return 0;
}
