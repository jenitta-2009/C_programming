#include <stdio.h>
int fact(int n);

int main()
{
    int number, result;

    printf("Enter a number: ");
    scanf("%d", &number);

    result = fact(number);

    printf("Factorial = %d\n", result);

    return 0;
}

int fact(int n) 
{
    int i, fact = 1;

    for(i = 1; i <= n; i++) 
    {
        fact = fact * i;
    }

    return fact;
}
