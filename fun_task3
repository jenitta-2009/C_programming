#include <stdio.h>

int check_Prime(int n);

int main() {
    int number;

    printf("Enter a number: ");
    scanf("%d", &number);

    if (check_Prime(number))
        printf("%d is a Prime Number\n", number);
    else
        printf("%d is Not a Prime Number\n", number);

    return 0;
}

int check_Prime(int n) {
    int i;

    if (n <= 1)
        return 0;

    for (i = 2; i < n; i++) {
        if (n % i == 0)
            return 0;
    }

    return 1;
}
