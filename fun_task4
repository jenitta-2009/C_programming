#include <stdio.h>
void swap(int *a, int *b);

int main() {
    int number1, number2;

    printf("Enter any two numbers: ");
    scanf("%d %d", &number1, &number2);

    printf("Before swap: %d,%d\n", number1, number2);
    swap(&number1, &number2);

    printf("After swap: %d,%d\n", number1, number2);

    return 0;
}

void swap(int *a, int *b) {
    int c;
     c= *a;
    *a = *b;
    *b = c;
}
